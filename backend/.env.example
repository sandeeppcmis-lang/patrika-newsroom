# ── Copy this file to .env and fill in your values ──────────────────────────
# Location: patrika-newsroom/backend/.env  (same folder as composer.json)

# RDS Database — get these from AWS RDS Console → your DB instance
DB_HOST=your-db-instance.xxxxxx.ap-south-1.rds.amazonaws.com
DB_NAME=patrika_newsroom
DB_USER=admin
DB_PASS=your_rds_password

# JWT — any long random string, keep secret
JWT_SECRET=change-this-to-any-32-plus-character-random-string

# AI service (optional — leave as-is if not using Python AI service yet)
AI_SERVICE_URL=http://localhost:8001

# Integrations (fill in later)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
TELEGRAM_BOT_TOKEN=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
