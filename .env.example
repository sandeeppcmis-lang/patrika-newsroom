# ── MySQL (required) ──────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=editorial_reports
MYSQL_TABLE_EMPLOYEES=user        # name of your existing employee table
# MYSQL_SSL=true                  # uncomment if your host requires SSL

# ── JWT Secret (required — change this to a long random string) ───────────────
JWT_SECRET=change-this-to-a-long-random-secret-string

# ── Server port ───────────────────────────────────────────────────────────────
PORT=3000

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI Assistant (optional) ───────────────────────────────────────────────────
# OPENAI_API_KEY=
